rules_version = '2';

// Firebase Storage rules for the iOS capture handoff.
// The iOS app uploads an Apple RoomPlan room.json to inbox/{CODE}.json
// (CODE = [A-Z2-9]{8}, alphabet excludes I, O, 0, 1); the web editor then
// fetches it via /editor?import=CODE. Objects in inbox/ are short-lived —
// a bucket lifecycle rule deletes them after 1 day (see README).
service firebase.storage {
  match /b/{bucket}/o {
    // Public read + create (no update/delete) for capture handoff files only.
    match /inbox/{file} {
      allow read: if file.matches('[A-Z2-9]{8}\\.json');
      allow create: if file.matches('[A-Z2-9]{8}\\.json')
                    && request.resource.size < 10 * 1024 * 1024
                    && request.resource.contentType == 'application/json';
      allow update, delete: if false;
    }

    // Everything else: denied.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
